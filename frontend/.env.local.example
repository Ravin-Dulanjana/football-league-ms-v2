# Backend URL — used by Next.js server-side route handlers to call FastAPI directly.
# On Vercel set this in the project environment variables.
# Locally: http://localhost:8000
API_BASE_URL=http://localhost:8000

# Optional — set the CloudFront domain for player/club image URLs.
# Leave blank locally. On production set to your CF distribution domain.
NEXT_PUBLIC_CLOUDFRONT_DOMAIN=
