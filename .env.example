DATABASE_URL=postgresql://postgres:postgres@localhost:5432/football_league
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret-for-production

# Phase 4 — S3 / CloudFront
# S3_BUCKET_NAME: output "MediaBucketName" from `cdk deploy`
# On EC2 this is injected by user_data.sh from the CDK stack context.
# For local development, create a bucket manually or leave blank (upload
# endpoints will fail, but all other endpoints are unaffected).
S3_BUCKET_NAME=

# CLOUDFRONT_DOMAIN: output "CloudFrontDomain" from `cdk deploy`
# e.g. d1abc2def3xyz.cloudfront.net  (no https:// prefix)
# get_file_url() builds: https://<CLOUDFRONT_DOMAIN>/<s3_key>
CLOUDFRONT_DOMAIN=
